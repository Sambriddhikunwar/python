erId":"03586353291564427136"}},"outputId":"a287778c-2ea1-4ebe-ca3f-292e2f9ab22a"},"execution_count":1,"outputs":[{"output_type":"stream","name":"stdout","text":["Ramesh Thapa | Original: 1985-06-24 AD | Converted: 24th Ashwin, 2041 BS\n","Sunita Karki | Original: 2055-09-10 BS | Converted: 1999-09-10 AD\n"]}]},{"cell_type":"code","source":["def word_frequency(text):\n","    # Convert to lowercase\n","    text = text.lower()\n","\n","    # Remove punctuation\n","    for ch in \".,!?;:\":\n","        text = text.replace(ch, \"\")\n","\n","    # Split into words\n","    words = text.split()\n","\n","    # Count frequencies\n","    freq = {}\n","    for word in words:\n","        freq[word] = freq.get(word, 0) + 1\n","\n","    # Sort by frequency (highest first)\n","    top_words = sorted(freq.items(), key=lambda x: x[1], reverse=True)[:3]\n","\n","    return top_words\n","\n","\n","# Test text\n","text = \"\"\"\n","Nepal is a beautiful country. Nepal has Mount Everest.\n","Everest is the highest mountain in the world.\n","Many tourists visit Nepal every year to see Everest and other mountains.\n","Nepal is known for its mountains and natural beauty.\n","\"\"\"\n","\n","# Display results\n","result = word_frequency(text)\n","\n","print(\"Top 3 words:\")\n","for word, count in result:\n","    print(f\"{word} — {count} times\")"],"metadata":{"id":"vyuMg1mUs5kG","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1780279388422,"user_tz":-345,"elapsed":11,"user":{"displayName":"Sambriddhi Kunwar","userId":"03586353291564427136"}},"outputId":"b8780b9b-1f8b-4f3e-f09f-e025da2d9585"},"execution_count":2,"outputs":[{"output_type":"stream","name":"stdout","text":["Top 3 words:\n","nepal — 4 times\n","is — 3 times\n","everest — 3 times\n"]}]},{"cell_type":"code","source":["accounts = {\n","    \"A001\": {\"name\": \"Ramesh Thapa\", \"balance\": 15000, \"pin\": \"1234\"},\n","    \"A002\": {\"name\": \"Sunita Karki\", \"balance\": 8500, \"pin\"